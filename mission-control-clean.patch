@@ -0,0 +1,59 @@
+import type { AiProvider, AiGenerationRequest, AiGenerationResponse } from '@/core/types/ai'
+
+export class GroqProvider implements AiProvider {
+  name = 'groq'
+  private apiKey: string
+
+  constructor() {
+    this.apiKey = process.env.GROQ_API_KEY || ''
+  }
+
+  isAvailable(): boolean {
+    return !!this.apiKey
+  }
+
+  async generate(request: AiGenerationRequest): Promise<AiGenerationResponse> {
+    if (!this.apiKey) throw new Error('Groq API key not configured')
+
+    const messages: { role: string; content: string }[] = []
+
+    if (request.system) {
+      messages.push({ role: 'system', content: request.system })
+    }
+
+    if (request.messages) {
+      messages.push(...request.messages.map((m: any) => ({ role: m.role, content: m.content })))
+    } else if (request.prompt) {
+      messages.push({ role: 'user', content: request.prompt })
+    }
+
+    const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        Authorization: `Bearer ${this.apiKey}`,
+      },
+      body: JSON.stringify({
+        model: 'llama-3.1-8b-instant',
+        messages,
+        max_tokens: request.maxTokens || 800,
+        temperature: request.temperature ?? 0.7,
+      }),
+    })
+
+    if (!res.ok) {
+      const err = await res.text()
+      throw new Error(`Groq error ${res.status}: ${err}`)
+    }
+
+    const data = await res.json()
+    const content = data.choices?.[0]?.message?.content || ''
+    const tokens = data.usage?.total_tokens
+
+    return {
+      content,
+      model: 'groq/llama-3.1-8b-instant',
+      tokens,
+    }
+  }
+}
