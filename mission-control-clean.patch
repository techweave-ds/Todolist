@@ -0,0 +1,122 @@
+'use client'
+
+import { useMemo } from 'react'
+import { Target, Flame, Brain, CheckCircle2 } from 'lucide-react'
+
+interface MissionHeroProps {
+  missions: any[]
+  streak: number
+  focusSessions: number
+  completedToday: number
+  recentXP?: number
+}
+
+const RANKS = [
+  { name: 'Cadet', min: 0 },
+  { name: 'Operator', min: 10 },
+  { name: 'Tactician', min: 25 },
+  { name: 'Strategist', min: 45 },
+  { name: 'Commander', min: 65 },
+  { name: 'Elite', min: 80 },
+  { name: 'Legend', min: 92 },
+  { name: 'Icon', min: 100 },
+]
+
+function getGreeting() {
+  const h = new Date().getHours()
+  if (h < 12) return 'Good morning'
+  if (h < 17) return 'Good afternoon'
+  return 'Good evening'
+}
+
+function getReadinessLabel(score: number) {
+  if (score >= 80) return { label: 'OPTIMAL', color: 'text-emerald-400' }
+  if (score >= 60) return { label: 'READY', color: 'text-primary' }
+  if (score >= 40) return { label: 'WARMING UP', color: 'text-yellow-400' }
+  return { label: 'NEEDS ACTIVATION', color: 'text-orange-400' }
+}
+
+export function MissionHero({ missions, streak, focusSessions, completedToday, recentXP = 0 }: MissionHeroProps) {
+  const activeMissions = missions.filter(m => m.status === 'active' || m.status === 'pending').length
+
+  const readiness = useMemo(() => {
+    const score =
+      Math.min(activeMissions * 25, 25) +
+      Math.min(focusSessions * 20, 20) +
+      Math.min(completedToday * 25, 25) +
+      Math.min(recentXP * 0.15, 15) +
+      Math.min(streak * 15, 15)
+    return Math.min(Math.round(score), 100)
+  }, [activeMissions, focusSessions, completedToday, recentXP, streak])
+
+  const { label, color } = getReadinessLabel(readiness)
+
+  const currentRank = RANKS.filter(r => readiness >= r.min).pop()?.name || 'Cadet'
+
+  return (
+    <div className="glass rounded-2xl p-6 bg-gradient-to-br from-primary/5 via-transparent to-accent/5 border border-primary/10">
+      <div className="flex items-start justify-between mb-4">
+        <div>
+          <p className="text-xs text-muted-foreground uppercase tracking-widest mb-1">
+            ■ SYSTEM ONLINE — {new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' })}
+          </p>
+          <h1 className="text-2xl font-bold">
+            {getGreeting()}, <span className="text-gradient">Commander</span>
+          </h1>
+          <p className="text-sm text-muted-foreground mt-1">
+            Your command center is online. All systems nominal.
+          </p>
+        </div>
+        <div className="flex flex-col items-end gap-1">
+          <div className="flex items-center gap-2">
+            <span className="text-3xl font-mono font-bold tabular-nums">{readiness}%</span>
+          </div>
+          <span className={`text-xs font-bold tracking-widest ${color}`}>{label}</span>
+          <span className="text-[10px] text-muted-foreground">{currentRank}</span>
+        </div>
+      </div>
+
+      {/* Readiness bar */}
+      <div className="mb-5">
+        <div className="w-full h-1.5 rounded-full bg-muted overflow-hidden">
+          <div
+            className="h-full rounded-full bg-gradient-to-r from-primary to-accent transition-all duration-1000"
+            style={{ width: `${readiness}%` }}
+          />
+        </div>
+      </div>
+
+      {/* Stat strip */}
+      <div className="grid grid-cols-4 gap-3">
+        <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-black/20">
+          <Target className="w-3.5 h-3.5 text-primary" />
+          <div>
+            <p className="text-xs font-bold tabular-nums">{activeMissions}</p>
+            <p className="text-[10px] text-muted-foreground">Active</p>
+          </div>
+        </div>
+        <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-black/20">
+          <Brain className="w-3.5 h-3.5 text-green-400" />
+          <div>
+            <p className="text-xs font-bold tabular-nums">{focusSessions}</p>
+            <p className="text-[10px] text-muted-foreground">Focus</p>
+          </div>
+        </div>
+        <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-black/20">
+          <Flame className="w-3.5 h-3.5 text-orange-400" />
+          <div>
+            <p className="text-xs font-bold tabular-nums">{streak}d</p>
+            <p className="text-[10px] text-muted-foreground">Streak</p>
+          </div>
+        </div>
+        <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-black/20">
+          <CheckCircle2 className="w-3.5 h-3.5 text-emerald-400" />
+          <div>
+            <p className="text-xs font-bold tabular-nums">{completedToday}</p>
+            <p className="text-[10px] text-muted-foreground">Done today</p>
+          </div>
+        </div>
+      </div>
+    </div>
+  )
+}
