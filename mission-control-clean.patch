diff -ruN '--exclude=.git' '--exclude=node_modules' '--exclude=.next' src/components/ui/glow-background.tsx src/components/ui/glow-background.tsx
--- src/components/ui/glow-background.tsx	1970-01-01 00:00:00.000000000 +0000
+++ src/components/ui/glow-background.tsx	2026-06-20 12:04:27.695195634 +0000
@@ -0,0 +1,105 @@
+'use client'
+
+import { useEffect, useRef } from 'react'
+
+interface Orb {
+  x: number
+  y: number
+  r: number
+  color: string
+  speed: number
+  angle: number
+  orbitR: number
+  cx: number
+  cy: number
+}
+
+export function GlowBackground() {
+  const canvasRef = useRef<HTMLCanvasElement>(null)
+  const mouseRef = useRef({ x: 0.5, y: 0.5 })
+  const targetMouseRef = useRef({ x: 0.5, y: 0.5 })
+  const frameRef = useRef<number>(0)
+  const tRef = useRef(0)
+
+  useEffect(() => {
+    const canvas = canvasRef.current
+    if (!canvas) return
+    const ctx = canvas.getContext('2d')
+    if (!ctx) return
+
+    let w = window.innerWidth
+    let h = window.innerHeight
+
+    const resize = () => {
+      w = canvas.width = window.innerWidth
+      h = canvas.height = window.innerHeight
+    }
+    resize()
+    window.addEventListener('resize', resize)
+
+    const onMouseMove = (e: MouseEvent) => {
+      targetMouseRef.current = { x: e.clientX / w, y: e.clientY / h }
+    }
+    window.addEventListener('mousemove', onMouseMove)
+
+    const orbs: Orb[] = [
+      { cx: 0.25, cy: 0.3, x: 0.25, y: 0.3, r: 0, speed: 0.0003, angle: 0, orbitR: 0.12, color: '139,92,246' },   // purple
+      { cx: 0.75, cy: 0.7, x: 0.75, y: 0.7, r: 0, speed: 0.0002, angle: 2.1, orbitR: 0.1, color: '192,38,211' },   // pink-magenta
+      { cx: 0.1, cy: 0.8, x: 0.1, y: 0.8, r: 0, speed: 0.00025, angle: 4.2, orbitR: 0.08, color: '59,130,246' },  // blue
+      { cx: 0.85, cy: 0.2, x: 0.85, y: 0.2, r: 0, speed: 0.00015, angle: 1.0, orbitR: 0.14, color: '168,85,247' }, // violet
+    ]
+
+    const draw = () => {
+      tRef.current += 1
+
+      // Smooth mouse interpolation
+      mouseRef.current.x += (targetMouseRef.current.x - mouseRef.current.x) * 0.04
+      mouseRef.current.y += (targetMouseRef.current.y - mouseRef.current.y) * 0.04
+
+      ctx.clearRect(0, 0, w, h)
+
+      orbs.forEach((orb) => {
+        orb.angle += orb.speed * 60
+        // Orbit center tracks slowly toward mouse
+        orb.cx += (mouseRef.current.x * 0.3 + orb.cx * 0.7 - orb.cx) * 0.003
+        orb.cy += (mouseRef.current.y * 0.3 + orb.cy * 0.7 - orb.cy) * 0.003
+
+        orb.x = orb.cx + Math.cos(orb.angle) * orb.orbitR
+        orb.y = orb.cy + Math.sin(orb.angle) * orb.orbitR * 0.6
+
+        const px = orb.x * w
+        const py = orb.y * h
+        const radius = Math.min(w, h) * (0.25 + 0.05 * Math.sin(tRef.current * 0.005 + orb.angle))
+
+        const grad = ctx.createRadialGradient(px, py, 0, px, py, radius)
+        grad.addColorStop(0, `rgba(${orb.color}, 0.13)`)
+        grad.addColorStop(0.5, `rgba(${orb.color}, 0.06)`)
+        grad.addColorStop(1, `rgba(${orb.color}, 0)`)
+
+        ctx.globalCompositeOperation = 'screen'
+        ctx.fillStyle = grad
+        ctx.beginPath()
+        ctx.arc(px, py, radius, 0, Math.PI * 2)
+        ctx.fill()
+      })
+
+      frameRef.current = requestAnimationFrame(draw)
+    }
+
+    draw()
+
+    return () => {
+      cancelAnimationFrame(frameRef.current)
+      window.removeEventListener('resize', resize)
+      window.removeEventListener('mousemove', onMouseMove)
+    }
+  }, [])
+
+  return (
+    <canvas
+      ref={canvasRef}
+      className="fixed inset-0 z-0 pointer-events-none"
+      style={{ mixBlendMode: 'screen' }}
+    />
+  )
+}
