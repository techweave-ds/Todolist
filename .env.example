# Supabase Auth (required for OAuth login with Google/GitHub)
# The app will work locally without these — it uses local auth via Prisma
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL for OAuth redirects
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — uses Neon/Postgres. Local SQLite fallback not supported.
# DATABASE_URL=postgresql://...
